<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/style.css">
  <link href="https://fonts.googleapis.com/css?family=Bangers&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css?family=Barlow+Condensed&display=swap" rel="stylesheet">
  <meta http-equiv="X-UA-Compatible" content="ie=edge">
  <title>Terry Loves Goals | Edit</title>
  <style>
    h1 {
      color: white;
      font-family: 'Bangers', cursive;
      font-size: 50px;
    }

    li {
      color: white;
      list-style-type: none;
      font-family: 'Bangers', cursive;
      font-size: 25px;
    }

    img {
      width: 66%;
      height: 66%;
    }

    .accomplished,
    .accomplished:active,
    .accomplished:visited {
      font-size: 28px;
      color: limegreen;
      font-family: 'Barlow Condensed', sans-serif;
      text-decoration: none;
    }

    .accomplished:hover,
    .unaccomplished:hover,
    .edit:hover {
      font-weight: bolder;
    }

    .unaccomplished,
    .unaccomplished:active,
    .unaccomplished:visited {
      font-size: 28px;
      color: red;
      font-family: 'Barlow Condensed', sans-serif;
      text-decoration: none;
    }

    .edit,
    .edit:active,
    .edit:visited {
      font-size: 28px;
      color: yellow;
      font-family: 'Barlow Condensed', sans-serif;
      text-decoration: none;
    }

    #editGoalText {
      background-color: transparent;
      outline-color: silver;
      color: white;
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 18px;
      width: 250px;
      height: 33px;
    }

    #editGoalSubmit {
      background-color: transparent;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: bolder;
      outline-color: silver;
      color: white;
      font-size: 18px;
      width: 250px;
      height: 40px;
    }

    .goBack {
      color: white;
      font-family: 'Bangers', cursive;
      font-size: 33px;
      text-decoration: none;
    }
  </style>
</head>

<body
  style="background-image: url('/image/terry-trippy.gif'); height: 752px; background-position: center; background-repeat: no-repeat; background-size: cover;">
  <div align='center'>]
    <h1>What's Your CHANGED Goal: </h1>
    <h1>{{name}}</h1>
    <br /><br />
    <a class="accomplished" href="/accomplished">Accomplished</a> |
    <a class="unaccomplished" href="/unaccomplished">Unaccomplished</a> |
    <a class="edit" href="/edit/{{id}}">Edit</a>
    <a class="goBack" href="/">Go Back</a>
    <br />
  </div>
</body>