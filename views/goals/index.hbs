<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/style.css">
  <meta http-equiv="X-UA-Compatible" content="ie=edge">
  <title>Terry Loves Goals | Home</title>
</head>

<body>
  <h1>Terry Loves Goals</h1>
    <ul>
      {{#each Goals}}
      <li>
        {{ Name }}
        <a class="accomplished" href="/views/goals/accomplished"><button>Accomplished</button></a>
        <a class="failed" href="/views/goals/failed"><button>Unaccomplished</button></a>
      </li>
      {{/each}}
    </ul>
</body>

</html>